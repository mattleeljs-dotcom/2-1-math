%% Section 1
%% 문제 1 - 배열 연산

% 행렬 A 정의
A = [1 4 2 2; 4 100 7 9; 7 3 pi 42];
B = log(A);           % B = ln(A)

% (a) B의 두 번째 행 선택
disp('(a) B의 두 번째 행:')
B(2, :)

% (b) B의 두 번째 행의 합
disp('(b) B의 두 번째 행의 합:')
sum(B(2, :))

% (c) B의 두 번째 열과 A의 첫 번째 열의 원소별 곱
disp('(c) B의 2열 .* A의 1열:')
result_c = B(:,2) .* A(:,1)

% (d) (c) 결과 벡터의 최대값
disp('(d) 최대값:')
max(result_c)

% (e) A의 1행 ./ B의 3열 처음 세 원소, 결과 합
disp('(e) 원소별 나눗셈 결과 합:')
result_e = A(1, 1:3) ./ B(1:3, 3)'; 
ans_e = sum(result_e)


%% Section 2
%% 문제 2 - 발사체 운동

% 초기값 설정
v0 = 50;                      % 초기 속도 (m/s)
A_deg = 50;                   % 발사각 (도)
A_rad = A_deg * pi / 180;     % 라디안 변환
g = 9.81;                     % 중력가속도 (m/s²)

% (a) 충돌 시간 thit 및 최고 높이 ymax
thit = 2 * v0 * sin(A_rad) / g;
t_top = v0 * sin(A_rad) / g;
ymax  = v0 * sin(A_rad) * t_top - 0.5 * g * t_top^2;

fprintf('충돌 시간 thit = %.4f 초\n', thit);
fprintf('최고 높이 ymax = %.4f m\n',  ymax);

% (b) 궤적 그래프 (x vs y)
t = linspace(0, thit, 500);
x = (v0 * cos(A_rad)) .* t;
y = (v0 * sin(A_rad)) .* t - 0.5 * g .* t.^2;

figure;
plot(x, y, 'b-', 'LineWidth', 2);
xlabel('x (m)');
ylabel('y (m)');
title('발사체 궤적 (v_0=50 m/s, θ=50°)');
grid on;


%% Section 3
%% 문제 3 - 함수 그래프

x = linspace(-2, 16, 1000);
f = (4 * cos(x)) ./ (x + exp(-0.75 * x));

figure;
plot(x, f, 'r-', 'LineWidth', 1.5);
xlabel('x');
ylabel('f(x)');
title('f(x) = 4cos(x) / (x + e^{-0.75x}),  -2 \leq x \leq 16');
grid on;



