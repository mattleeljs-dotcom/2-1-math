%% 문제 5 - 다항식 연산

% (a) 다항식 곱: (5x⁴-3x²+7x+10)(4x³-7x²+9x+2)
p1 = [5  0 -3  7 10];    % 5x⁴ + 0x³ - 3x² + 7x + 10
p2 = [4 -7  9  2];       % 4x³ - 7x² + 9x + 2
disp('(a) 다항식 곱의 계수:')
product = conv(p1, p2)

% (b) 다항식 나눗셈: (5x³-7x²+2x+8) ÷ (6x²+3x-2)
num = [5 -7  2  8];
den = [6  3 -2];
disp('(b) 몫(q)과 나머지(r) 계수:')
[q, r] = deconv(num, den)

% (c) x=5에서 (36x³-8x²+2) / (36x³-5x²+4x-3) 계산
num2 = [36 -8  0  2];
den2 = [36 -5  4 -3];
x_val = 5;
result = polyval(num2, x_val) / polyval(den2, x_val);
fprintf('(c) x=5에서의 값: %.6f\n', result);


